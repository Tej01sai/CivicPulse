# ══════════════════════════════════════════════
#  CivicPulse — .gitignore
# ══════════════════════════════════════════════

# ── Environment / Secrets (NEVER commit these) ─
.env
.env.*
!.env.example          # keep the example template
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.production.local
frontend/.env.development.local

# ── Python ─────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
site-packages/

# Virtual environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# Python tooling
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# ── Node / Frontend ─────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
*.tsbuildinfo

# ── IDE & Editor ────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Database ────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Build artifacts ──────────────────────────────
*.pyc
*.pyo
*.so
